# ── OpenAI ────────────────────────────────────────────────────────────────────
# Your secret key from platform.openai.com/api-keys
# Required — the pipeline cannot call GPT-4o or create embeddings without this
OPENAI_API_KEY=your-openai-key-here

# ── LangSmith (observability) ─────────────────────────────────────────────────
# Your LangSmith secret key from smith.langchain.com
# Required for tracing — every LLM call is recorded as a trace in LangSmith
LANGCHAIN_API_KEY=ls__your-langsmith-key-here

# Turn LangSmith tracing on (true) or off (false)
# Set to false if you want to run without observability during local testing
LANGCHAIN_TRACING_V2=true

# The URL LangSmith listens on — almost never changes
# Only modify this if your company runs a self-hosted LangSmith instance
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# The project name traces are filed under inside LangSmith
# Change this if you want traces grouped under a different project name
LANGCHAIN_PROJECT=rag-analytics-assistant

# ── Jira (human-in-the-loop escalation) ──────────────────────────────────────
# Your company's Jira base URL — find it by logging into Jira and copying the domain
# Example: https://acmecorp.atlassian.net
JIRA_BASE_URL=https://yourcompany.atlassian.net

# The email address you use to log into Jira / Atlassian
JIRA_EMAIL=your-email@company.com

# Your Jira API token — NOT your Jira password
# Generate one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token-here

# The short key of the Jira project where escalation stories will be created
# Find it in Jira — it appears before every ticket number e.g. ANALYTICS-142
JIRA_PROJECT_KEY=ANALYTICS

# ── ChromaDB (vector store) ───────────────────────────────────────────────────
# Folder path where ChromaDB saves the embedded document vectors on disk
# This folder is gitignored and rebuilt by running: python ingest.py --reset
CHROMA_PERSIST_DIR=./chroma_db

# ── Document chunking ─────────────────────────────────────────────────────────
# Maximum number of characters per chunk when splitting documents
# Smaller = more precise retrieval but loses context | Larger = more context but less precise
# Experiment with 200, 500, 800 in Phase 2 and record results in FINDINGS.md
CHUNK_SIZE=500

# How many characters the next chunk re-reads from the previous one
# Prevents information being lost at chunk boundaries
CHUNK_OVERLAP=50

# How many chunks to retrieve from ChromaDB per question
# Higher = more context for the LLM but more tokens spent per query
TOP_K_RESULTS=3

# Minimum similarity score (0.0 to 1.0) a chunk must reach to be used
# Chunks scoring below this are discarded — question triggers escalation instead
# Lower = more permissive | Higher = stricter, more escalations
SIMILARITY_THRESHOLD=0.7

# ── Models ────────────────────────────────────────────────────────────────────
# Which OpenAI model generates the answers
# gpt-4o is the default — change to gpt-4o-mini to reduce cost during development
MODEL=gpt-4o

# Which OpenAI model turns text into vectors for storage and retrieval
# text-embedding-3-small produces 1536-dimensional vectors at very low cost
EMBEDDING_MODEL=text-embedding-3-small

# ── LLM behaviour ─────────────────────────────────────────────────────────────
# Maximum number of tokens in the LLM response
# 400 is suitable for factual Q&A answers
# Increase to 600-800 for detailed summaries
# Decrease to 200-300 to reduce cost on short answers
MAX_TOKENS=400

# Controls creativity and randomness of LLM responses
# Range: 0.0 to 1.0
# 0.0 = fully deterministic, same answer every time
# 0.2 = very low creativity, factual and consistent (recommended for RAG)
# 0.5 = moderate variation in phrasing
# 1.0 = highly creative and unpredictable
TEMPERATURE=0.2

# Number of times to retry an OpenAI call if it fails due to rate limiting
MAX_RETRIES=2

# ── Logging ───────────────────────────────────────────────────────────────────
# Controls how much detail appears in the console and log file
# DEBUG = everything | INFO = normal operation | WARNING = problems only | ERROR = failures only
LOG_LEVEL=INFO

